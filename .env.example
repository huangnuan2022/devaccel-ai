APP_NAME=DevAccel-AI
APP_ENV=local
API_PREFIX=/api/v1
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://devaccel:devaccel@localhost:5433/devaccel
TEST_DATABASE_URL=postgresql+psycopg://devaccel:devaccel@localhost:5433/devaccel_test
REDIS_URL=redis://localhost:6379/0

LLM_PROVIDER=mock
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
AWS_REGION=us-east-1

GITHUB_APP_ID=your-github-app-id
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
GITHUB_API_VERSION=2022-11-28
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_PRIVATE_KEY_PATH=secrets/github-app.pem

DYNAMODB_TABLE=devaccel-artifacts
SQS_QUEUE_URL=https://example.queue.amazonaws.com/123456789012/devaccel-analysis
CLOUDWATCH_LOG_GROUP=/aws/ecs/devaccel-ai
